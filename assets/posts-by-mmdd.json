---
layout: null
permalink: /assets/posts-by-mmdd.json
sitemap: false
---
{%- assign all = site.notes | where_exp: "p", "p.date" | where_exp: "p", "p.published != false" | sort: "date" | reverse -%}
{
  "generated": "{{ site.time | date: '%Y-%m-%dT%H:%M:%SZ' }}",
  "posts": [
{%- for p in all %}
    {
      "date": "{{ p.date | date: '%Y-%m-%d' }}",
      "year": {{ p.date | date: '%Y' }},
      "mmdd": "{{ p.date | date: '%m-%d' }}",
      "title": {{ p.title | jsonify }},
      "url": "{{ p.url | relative_url }}",
      "category": {{ p.main_category | default: "" | jsonify }},
      "subCategory": {{ p.sub_category | default: "" | jsonify }}
    }{%- unless forloop.last -%},{%- endunless -%}
{%- endfor %}
  ]
}