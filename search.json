---
layout: null
---
[
  {% assign items = site.notes %}
  {% for item in items %}

    {%- assign cat_str = "" -%}

    {%- if item.main_category -%}
      {%- assign cat_str = item.main_category -%}
    {%- elsif item.discipline -%}
      {%- assign cat_str = "学习资料" -%}
    {%- endif -%}

    {%- if item.discipline -%}
      {%- if cat_str != "" -%}{%- assign cat_str = cat_str | append: " · " -%}{%- endif -%}
      {%- assign cat_str = cat_str | append: item.discipline -%}
    {%- endif -%}

    {%- if item.course -%}
      {%- if cat_str != "" -%}{%- assign cat_str = cat_str | append: " · " -%}{%- endif -%}
      {%- assign cat_str = cat_str | append: item.course -%}
    {%- endif -%}

    {%- if item.sub_category -%}
      {%- if cat_str != "" -%}{%- assign cat_str = cat_str | append: " · " -%}{%- endif -%}
      {%- assign cat_str = cat_str | append: item.sub_category -%}
    {%- endif -%}

    {%- if item.material_type -%}
      {%- if cat_str != "" -%}{%- assign cat_str = cat_str | append: " · " -%}{%- endif -%}
      {%- assign cat_str = cat_str | append: item.material_type -%}
    {%- endif -%}

    {%- if cat_str == "" -%}
      {%- if item.categories.size > 0 -%}
        {%- assign cat_str = item.categories | first -%}
      {%- else -%}
        {%- assign cat_str = "未分类" -%}
      {%- endif -%}
    {%- endif -%}

    {%- comment -%} 顶部导航搜索 = 所有分栏搜索能力的并集：
        标题 + 每篇 keywords + 菜谱 tags + 课程别名 + 学科/课程/类型 {%- endcomment -%}
    {%- assign kw = item.title -%}
    {%- if item.keywords -%}{%- assign _k = item.keywords | join: ' ' -%}{%- assign kw = kw | append: ' ' | append: _k -%}{%- endif -%}
    {%- if item.tags -%}{%- assign _t = item.tags | join: ' ' -%}{%- assign kw = kw | append: ' ' | append: _t -%}{%- endif -%}
    {%- assign _al = site.data.course_aliases[item.course] -%}
    {%- if _al -%}{%- assign kw = kw | append: ' ' | append: _al -%}{%- endif -%}
    {%- assign kw = kw | append: ' ' | append: cat_str -%}
    {
      "title"    : {{ item.title | jsonify }},
      "category" : {{ cat_str | jsonify }},
      "keywords" : {{ kw | jsonify }},
      "url"      : "{{ site.baseurl }}{{ item.url }}",
      "date"     : "{{ item.date | date: '%Y-%m-%d' }}"
    }{% unless forloop.last %},{% endunless %}
  {% endfor %}
  {%- assign live_tools = site.data.toolbox | where: "status", "live" -%}
  {%- if live_tools.size > 0 and items.size > 0 -%},{%- endif -%}
  {% for tool in live_tools %}
    {%- assign tkw = tool.name | append: ' ' | append: tool.tagline | append: ' ' | append: tool.category -%}
    {
      "title"    : {{ tool.name | jsonify }},
      "category" : {{ "工具 · " | append: tool.category | jsonify }},
      "keywords" : {{ tkw | jsonify }},
      "url"      : "{{ site.baseurl }}{{ tool.url }}",
      "date"     : ""
    }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]
