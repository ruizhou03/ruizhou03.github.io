source 'https://rubygems.org'

# 用现代 Jekyll 4.x 做本地预览。
# 注意：GitHub Pages 服务器实际用 Jekyll 3.10，所以本地构建结果只是"很接近"，
# 不是完全一致。但对纯 markdown + Liquid 模板的站，差异极小。
gem 'jekyll', '~> 4.3'

# _config.yml 里启用的插件
gem 'jekyll-seo-tag'
gem 'jekyll-sitemap'
gem 'jekyll-feed'

# Ruby 3.0+ 不再自带 webrick；jekyll serve 必须装
gem 'webrick'

# Ruby 3.4+ 不再自带 csv（kramdown 之类用得到）
gem 'csv'
