{
  "permissions": {
    "allow": [
      "Bash(grep -n \"// ============================================================\\\\s*$\" $CLAUDE_PROJECT_DIR/toolbox/doudizhu/index.html)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/scripts/hooks/pre_bash_audit_no_commit.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/scripts/hooks/post_write_imgslim.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/scripts/hooks/stop_publish_reminder.sh"
          }
        ]
      }
    ]
  }
}
